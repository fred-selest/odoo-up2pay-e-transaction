<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Hériter la vue formulaire du provider de paiement pour ajouter les champs spécifiques Up2pay -->
    <record id="payment_provider_form_up2pay" model="ir.ui.view">
        <field name="name">payment.provider.form.up2pay</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <!-- Ajouter les champs de configuration Up2pay dans l'onglet Configuration -->
            <xpath expr="//page[@name='configuration']" position="inside">
                <group string="Configuration Up2pay E-Transactions" name="up2pay_configuration" 
                       attrs="{'invisible': [('code', '!=', 'up2pay')]}">
                    <group string="Identifiants Marchand">
                        <field name="pbx_site" placeholder="ex: 12345678"/>
                        <field name="pbx_rang" placeholder="ex: 1"/>
                        <field name="pbx_identifiant" placeholder="ex: MERCHANT_ID"/>
                        <field name="pbx_hmac_key" placeholder="Entrez la clé HMAC au format hexadécimal" password="True"/>
                    </group>
                    <group string="Mode et URLs">
                        <field name="test_mode"/>
                        <field name="production_url" attrs="{'invisible': [('test_mode', '=', True)]}" 
                               placeholder="https://tpeweb.e-transactions.fr/php/"/>
                    </group>
                    <group string="Pages de Retour (optionnel)">
                        <field name="pbx_effectue" placeholder="/payment/process"/>
                        <field name="pbx_refuse" placeholder="/payment/process"/>
                        <field name="pbx_annule" placeholder="/payment/process"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
